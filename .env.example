# AI Trading API - Environment Variables
# Copy this file to .env and fill in the values

# Google Apps Script Web App URL (required for Sheets DB)
GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# GAS request timeout in seconds
GAS_TIMEOUT=10

# SQLite database path (auto-created, cross-platform)
# Leave empty to use default: ./data/trading.db
DB_PATH=

# Ollama LLM server URL (for local AI)
OLLAMA_URL=http://localhost:11434

# API security key (optional, leave empty to disable auth)
API_KEY=

# CORS allowed origins (comma-separated, * for all)
ALLOWED_ORIGINS=*

# Cloudflare Tunnel URL (for external access)
TUNNEL_URL=

# Server port
PORT=8000
